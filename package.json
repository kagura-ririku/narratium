{
  "name": "Narratium",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 5000 --turbopack",
    "build": "next build",
    "lint": "eslint .",
    "preview": "serve -s out",
    "test": "vitest",
    "pake-mac": "pake out/index.html --name Narratium --use-local-file --icon ./public/icon.icns --multi-arch",
    "pake-win": "pake out/index.html --name Narratium --use-local-file --icon ./public/icon.ico",
    "pake-linux": "pake out/index.html --name narratium --use-local-file --icon ./public/icon.png"
  },
  "dependencies": {
    "@vercel/analytics": "latest",
    "framer-motion": "latest",
    "gsap": "latest",
    "lucide-react": "latest",
    "next": "latest",
    "png-chunk-text": "latest",
    "png-chunks-encode": "latest",
    "png-chunks-extract": "latest",
    "react": "latest",
    "react-color": "latest",
    "react-dom": "latest",
    "react-hot-toast": "latest",
    "react-parallax-tilt": "latest",
    "reactflow": "latest",
    "uuid": "latest",
    "zustand": "latest"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "latest",
    "@tailwindcss/postcss": "latest",
    "@types/node": "latest",
    "@types/png-chunk-text": "latest",
    "@types/png-chunks-encode": "latest",
    "@types/png-chunks-extract": "latest",
    "@types/react-color": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@typescript-eslint/eslint-plugin": "latest",
    "@typescript-eslint/parser": "latest",
    "eslint": "latest",
    "eslint-config-next": "latest",
    "tailwindcss": "latest",
    "typescript": "latest",
    "vite": "latest",
    "vitest": "latest"
  }
}
